STRIPE_PRICE_FOUNDING_USD="price_..."
STRIPE_PRICE_FOUNDING_INR="price_..."
STRIPE_PRICE_ONETIME_USD="price_..."
STRIPE_PRICE_ONETIME_INR="price_..."

# Resend (email)
